{
  "name": "@vue-storefront/magento-theme",
  "description": "Magento2 Integration for Vue Storefront 2",
  "version": "1.3.1",
  "private": true,
  "license": "MIT",
  "homepage": "https://github.com/vuestorefront/magento2",
  "bugs": {
    "url": "https://github.com/vuestorefront/magento2/issues"
  },
  "scripts": {
    "dev": "concurrently \"nuxt\" \"yarn start:middleware\"",
    "dev:debug": "node --inspect ../../node_modules/.bin/nuxt dev",
    "dev:frontend": "nuxt",
    "build": "nuxt build --modern=client",
    "build:analyze": "nuxt build -a --modern=client",
    "lhci:mobile": "lhci autorun",
    "lint": "eslint . --ext .ts,.vue",
    "lint:fix": "eslint . --ext .ts,.vue --fix",
    "start": "nuxt start --modern=client",
    "start:middleware": "node middleware.js",
    "test": "jest",
    "test:e2e": "cypress open --config-file __tests__/e2e/cypress.json",
    "test:e2e:hl": "cypress run --headless --config-file __tests__/e2e/cypress.json",
    "test:e2e:generate:report": "yarn -s mochawesome-merge \"__tests__/e2e/report/*.json\" > \"__tests__/e2e/report.json\" && yarn -s marge __tests__/e2e/report.json -o \"__tests__/e2e/report\"",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@nuxt/image": "latest",
    "@nuxtjs/device": "latest",
    "@nuxtjs/recaptcha": "latest",
    "@nuxtjs/style-resources": "latest",
    "@pinia/nuxt": "latest",
    "@storefront-ui/vue": "latest",
    "@vue-storefront/cache": "latest",
    "@vue-storefront/http-cache": "latest",
    "@vue-storefront/magento-api": "latest",
    "@vue-storefront/middleware": "latest",
    "@vue-storefront/nuxt": "latest",
    "@vue-storefront/redis-cache": "latest",
    "axios": "latest",
    "body-parser": "latest",
    "body-scroll-lock": "latest",
    "cookie-universal-nuxt": "latest",
    "deepdash": "latest",
    "dotenv": "latest",
    "isomorphic-dompurify": "latest",
    "lodash-es": "latest",
    "nuxt": "latest",
    "nuxt-i18n": "latest",
    "omit-deep": "latest",
    "patch-package": "latest",
    "pinia": "latest",
    "proxy-from-env": "latest",
    "vee-validate": "latest",
    "vue": "latest",
    "vue-lazy-hydration": "latest",
    "vue-scrollto": "latest"
  },
  "devDependencies": {
    "@commitlint/config-conventional": "latest",
    "@lhci/cli": "latest",
    "@nuxt/types": "latest",
    "@pinia/testing": "latest",
    "@testing-library/jest-dom": "latest",
    "@testing-library/user-event": "latest",
    "@testing-library/vue": "latest",
    "@types/lodash-es": "latest",
    "@typescript-eslint/eslint-plugin": "latest",
    "@typescript-eslint/parser": "latest",
    "@vite-pwa/nuxt": "^0.5.0",
    "@vue-storefront/magento-types": "latest",
    "@vue/eslint-config-typescript": "latest",
    "@vue/runtime-dom": "latest",
    "@vue/test-utils": "latest",
    "commitlint": "latest",
    "concurrently": "latest",
    "cors": "latest",
    "cypress": "latest",
    "cypress-pipe": "latest",
    "cypress-tags": "latest",
    "deepmerge": "latest",
    "ejs": "latest",
    "eslint": "latest",
    "eslint-config-airbnb-base": "latest",
    "eslint-config-airbnb-typescript": "latest",
    "eslint-import-resolver-typescript": "latest",
    "eslint-plugin-import": "latest",
    "eslint-plugin-jest": "latest",
    "eslint-plugin-node": "latest",
    "eslint-plugin-promise": "latest",
    "eslint-plugin-unicorn": "latest",
    "eslint-plugin-vue": "latest",
    "jest": "latest",
    "jest-date-mock": "latest",
    "jest-localstorage-mock": "latest",
    "jest-silent-reporter": "latest",
    "jest-transform-stub": "latest",
    "jest-watch-toggle-config": "latest",
    "jest-watch-typeahead": "latest",
    "lint-staged": "latest",
    "majestic": "latest",
    "mocha": "latest",
    "mochawesome": "latest",
    "mochawesome-merge": "latest",
    "mochawesome-report-generator": "latest",
    "npm-check-updates": "latest",
    "postinstall-postinstall": "latest",
    "ts-jest": "latest",
    "ts-loader": "latest",
    "ts-node": "latest",
    "tslib": "latest",
    "typescript": "latest",
    "vue-eslint-parser": "latest",
    "vue-jest": "latest",
    "webpack": "latest"
  }
}
