{
  "name": "@mframework/layer-commerce",
  "version": "0.0.7",
  "description": "Commerce Layer for the M Framework",
  "keywords": [
    "commerce",
    "mframework-framework",
    "nuxt",
    "layer"
  ],
  "license": "MIT",
  "author": "M Framework",
  "type": "module",
  "main": "./nuxt.config.ts",
  "scripts": {
    "test": "vitest",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint 'src/**/*.{ts,tsx}' || true",
    "prepare": "npm run build",
    "prepublishOnly": "npm run typecheck && npm run build",
    "codegen": "npx graphql-codegen --config ./node_modules/@mframework/adapter-magento/codegen.ts"
  },
  "dependencies": {
    "@better-auth/stripe": "^1.4.15",
    "@mframework/core": "^0.0.4",
    "@polar-sh/sdk": "^0.42.2",
    "@storefront-ui/nuxt": "^3.1.1",
    "@tilework/opus": "^0.0.12",
    "history": "^5.3.0",
    "jwt-decode": "^4.0.0",
    "lodash-es": "^4.17.23"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@vitest/coverage-v8": "^4.0.17",
    "eslint": "^8.0.0",
    "jest-cucumber": "^4.5.0",
    "nuxt": "^4.3.0",
    "typescript": "^5.8.2"
  }
}
