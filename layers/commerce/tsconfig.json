{
  "compilerOptions": {
    "declaration": true,
    "emitDeclarationOnly": false,
    "outDir": "dist",
    "moduleResolution": "bundler",
    "module": "ESNext",
    "target": "ESNext",
    "strict": false,
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "noEmitOnError": false
  },
  "include": [
    "src",
    "index.ts",
    "app",
    "app/**/*.vue",
    "app/types",
    "global.d.ts",
    "app/utils/client.ts",
    "app/utils/normalizers"
  ]
  ,
  "exclude": [
    "**/__tests__/**",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "node_modules"
  ]
}