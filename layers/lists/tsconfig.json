{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "#shared/*": ["../shared/*"],
      "@mframework/core": ["../../packages/core/index.ts"],
      "@mframework/core/*": ["../../packages/core/*"]
    },
    "declaration": true,
    "emitDeclarationOnly": false,
    "outDir": "dist",
    "moduleResolution": "node",
    "module": "ESNext",
    "target": "ESNext",
    "strict": true,
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "noEmitOnError": false
  }
}
