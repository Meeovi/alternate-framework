# Local development environment variables for layers/auth
# Copy this file to .env or .env.local and edit values before running

# PostgreSQL connection used by Prisma via alternate-gateway/core
NUXT_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mframework_dev

# BetterAuth secret (MIN 32 chars). Use a random value in production.
BETTER_AUTH_SECRET=2f9b8c3e6a1d4f7e9c2b4a6d8f0e1c3a7b9d2f4a6c8e0b1d3f5a7c9e1b2d3f4

# Base URL used by BetterAuth and some providers
BASE_URL=http://localhost:3006

# Optional Mastodon proxy base URL (if you run a local instance)
MASTO_BASE_URL=

# Redis URL for MCP or session storage if needed
REDIS_URL=
