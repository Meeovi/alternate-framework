{
  "extends": "./.nuxt/tsconfig.json",
  "compilerOptions": {
    "target": "ES2020",
    "verbatimModuleSyntax": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "paths": {
      "alternate-gateway/core": ["../../packages/modules/alternate-gateway/core/index.ts"],
      "alternate-gateway/core/*": ["../../packages/modules/alternate-gateway/core/src/*"],
      "alternate-auth": ["../../packages/modules/alternate-auth/index.ts"],
      "alternate-auth/*": ["../../packages/modules/alternate-auth/*"],
      "@mframework/adapter-betterauth": ["./app/utils/adapter-betterauth/index.ts"],
      "@mframework/adapter-betterauth/": ["./app/utils/adapter-betterauth/index.ts"],
      "@mframework/adapter-betterauth/*": ["./app/utils/adapter-betterauth/*"]
    }
  }
}