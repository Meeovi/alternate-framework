{
  "compilerOptions": {
    "baseUrl": ".",
    "types": ["node", "vitest", "vue", "nuxt"],
    "declaration": true,
    "emitDeclarationOnly": false,
    "outDir": "dist",
    "module": "ESNext",
    "target": "ES2017",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "lib": ["ES2017", "DOM", "DOM.Iterable"],
    "strict": false,
    "noImplicitAny": false,
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "noEmitOnError": false
    ,
    "paths": {
      "@mframework/adapter-betterauth": ["app/utils/adapter-betterauth/index.ts"],
      "@mframework/adapter-betterauth/": ["app/utils/adapter-betterauth/index.ts"],
      "@mframework/adapter-betterauth/*": ["app/utils/adapter-betterauth/*"],
      "@mframework/core": ["types/mframework-core.d.ts", "../../packages/modules/core/src/index.ts"],
      "#shared/*": ["../social/shared/*"]
    }
  }
  ,
  "exclude": [
    "node_modules",
    "dist"
  ],
  "include": [
    "app/**/*",
    "server/**/*",
    "types/**/*.d.ts"
  ]
}