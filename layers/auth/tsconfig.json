{
  "compilerOptions": {
    "baseUrl": ".",
    "types": ["node", "vitest"],
    "declaration": true,
    "emitDeclarationOnly": false,
    "outDir": "dist",
    "module": "ESNext",
    "target": "ES2017",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "lib": ["ES2017", "DOM"],
    "strict": true,
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "noEmitOnError": false
    ,
    "paths": {
      "@mframework/adapter-betterauth": ["../../packages/adapters/adapter-betterauth/src/index.ts"],
      "@mframework/adapter-betterauth/*": ["../../packages/adapters/adapter-betterauth/src/*"]
      ,
      "@mframework/core": ["../../packages/modules/core/src/index.ts"]
    }
  }
  ,
  "exclude": [
    "node_modules",
    "dist"
  ],
  "include": [
    "app/**/*",
    "server/**/*"
  ]
}