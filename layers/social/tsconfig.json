{
  "compilerOptions": {
    "types": ["node", "vitest"],
    "declaration": true,
    "emitDeclarationOnly": false,
    "outDir": "dist",
    "moduleResolution": "bundler",
    "module": "ESNext",
    "target": "ESNext",
    "strict": true,
    "jsx": "react-jsx",
    "skipLibCheck": true, 
    "noEmitOnError": false
  }
  ,
  "include": [
    "src/**/*",
    "app/**/*",
    "index.ts",
    "package.json"
, "global.d.ts"  ]
}