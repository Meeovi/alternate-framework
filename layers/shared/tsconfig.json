{
  "compilerOptions": {
    "types": ["vitest", "node", "@nuxt/test-utils", "@vue/test-utils"],
    "declaration": true,
    "emitDeclarationOnly": false,
    "outDir": "dist",
    "moduleResolution": "bundler",
    "module": "ESNext",
    "target": "ESNext",
    "strict": true,
    "jsx": "react-jsx",
    "skipLibCheck": true, 
    "noEmitOnError": false
  },
  "include": [
    "app/composables/types.ts",
    "app/composables/registry.ts",
    "app/composables/useContent.ts",
    "app/composables/useDirectusRequest.ts",
    "README.md",
    "package.json"
    ,"src/global.d.ts"
  ],
  "exclude": [
    "**/__tests__/**",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "node_modules"
  ]
}