{
  "name": "alternate-framework",
  "version": "1.0.0",
  "private": true,
  "description": "Alternate Framework — Vue + Nuxt 4 starter and integrations",
  "main": "apps/Meeovi/nuxt.config.ts",
  "scripts": {
    "dev": "cd apps/Meeovi && npx nuxi dev",
    "build": "cd apps/Meeovi && npx nuxi build",
    "preview": "cd apps/Meeovi && npx nuxi preview",
    "typecheck": "bash ./scripts/typecheck",
    "create-adapter": "./scripts/create-adapter",
    "lint": "echo \"No lint script configured\" && exit 0"
  },
  "bin": {
    "meeovi-create-adapter": "packages/core/bin/create-adapter.cjs"
  },
  "keywords": ["vue", "nuxt", "alternate-framework", "meeovi"],
  "author": "Meeovi",
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.9.3"
  },
  "packageManager": "npm@8.5.0",
  "workspaces": [
    "apps/*",
    "packages/*",
    "layers/*",
    "integrations/*",
    "themes/*",
    "docs/*"
  ]
}