{
  "packageManager": "npm@11.6.2",
  "name": "mframework",
  "version": "1.0.0",
  "private": true,
  "description": "M Framework — Vue + Nuxt 4 starter and integrations",
  "main": "apps/ecosystem/meeovi-frontend/nuxt.config.ts",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "preview": "cd apps/ecosystem/meeovi-frontend && npx nuxi preview"
  },
  "bin": {
    "meeovi-create-adapter": "packages/core/bin/create-adapter.cjs"
  },
  "keywords": [
    "vue",
    "nuxt",
    "mframework",
    "meeovi"
  ],
  "author": "M Framework",
  "license": "MIT",
  "devDependencies": {
    "turbo": "^2.8.11",
    "typescript": "^5.9.3"
  },
  "workspaces": [
    "packages/*",
    "packages/modules/*",
    "layers/*",
    "themes/*",
    "docs/*"
  ],
  "dependencies": {
    "flat": "^6.0.1",
    "@polar-sh/sdk": "^0.47.0"
  },
  "overrides": {
    "vue": "^3.5.29"
  }
