{
  "name": "mframework",
  "version": "1.0.0",
  "private": true,
  "description": "M Framework — Vue + Nuxt 4 starter and integrations",
  "main": "apps/Meeovi/nuxt.config.ts",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "preview": "cd apps/Meeovi && npx nuxi preview",
    "typecheck": "bash ./scripts/typecheck",
    "prisma:api": "node ./scripts/run-prisma-api.js",
    "create-adapter": "./scripts/create-adapter"
  },
  "bin": {
    "meeovi-create-adapter": "packages/core/bin/create-adapter.cjs"
  },
  "keywords": [
    "vue",
    "nuxt",
    "mframework",
    "meeovi"
  ],
  "author": "M Framework",
  "license": "MIT",
  "devDependencies": {
    "lightningcss": "^1.31.1",
    "turbo": "^2.8.11",
    "typescript": "^5.9.3"
  },
  "packageManager": "npm@8.5.0",
  "workspaces": [
    "packages/*",
    "layers/*",
    "integrations/*",
    "themes/*",
    "docs/*"
  ],
  "dependencies": {
    "flat": "^6.0.1"
  },
  "overrides": {
    "vue": "^3.5.29"
  }
}
