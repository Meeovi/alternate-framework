#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
cd "$ROOT_DIR"

TSFILES=$(git ls-files "**/tsconfig.json" || true)
if [ -z "$TSFILES" ]; then
  echo "No tsconfig.json files found."
  exit 0
fi

STATUS=0
echo "Found tsconfig files:"\n$TSFILES

for f in $TSFILES; do
  DIR=$(dirname "$f")
  echo "\n== Typechecking: $DIR =="
  if ! npx -y -p typescript tsc -p "$DIR" --noEmit; then
    STATUS=1
  fi
done

if [ $STATUS -ne 0 ]; then
  echo "\nTypecheck finished: issues found." >&2
  exit 1
fi

echo "\nTypecheck finished: no issues." 
exit 0
