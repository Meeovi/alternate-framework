{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    // "ignoreDeprecations": "6.0",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "allowJs": true,
    "types": ["node"],
    "baseUrl": ".",
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "paths": {
      "~/*": [
        "./layers/commerce/app/*",
        "./layers/commerce/*",
        "./layers/social/app/*",
        "./layers/social/*",
        "./layers/shared/app/*",
        "./layers/shared/*",
        "./apps/Meeovi/*"
      ],
      "@/*": [
        "./layers/commerce/app/*",
        "./layers/commerce/*",
        "./layers/social/app/*",
        "./layers/social/*",
        "./layers/shared/app/*",
        "./layers/shared/*",
        "./apps/Meeovi/*"
      ]
    },
    "typeRoots": ["./types", "./node_modules/@types"]
  },
  "include": [
    "packages/modules/api/**/*",
    "layers/shared/**/*",
    "layers/social/**/*",
    "layers/commerce/**/*",
    "layers/auth/server/api/org-members.get.ts",
    "layers/auth/server/utils/commerce-admin.ts",
    "layers/auth/server/utils/admin-access.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/node_modules/**",
    "**/dist/**",
    "**/__tests__/**",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "**/*.test.ts",
    "**/*.test.tsx"
  ]
}
