{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "node",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "allowJs": true,
    "types": ["node"],
    "baseUrl": ".",
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "paths": {
      "alternate-gateway/core": ["packages/modules/alternate-gateway/core/index.ts"],
      "alternate-gateway/core/*": ["packages/modules/alternate-gateway/core/src/*"],
      "#shared/*": ["packages/modules/alternate-gateway/core/src/shared/*"],
      "#shared": ["packages/modules/alternate-gateway/core/src/shared"],
      
      "~/*": [
        "./layers/commerce/app/*",
        "./layers/commerce/*",
        "./layers/social/app/*",
        "./layers/social/*",
        "./layers/shared/app/*",
        "./layers/shared/*",
        "./apps/Meeovi/*"
      ],
      "@/*": [
        "./layers/commerce/app/*",
        "./layers/commerce/*",
        "./layers/social/app/*",
        "./layers/social/*",
        "./layers/shared/app/*",
        "./layers/shared/*",
        "./apps/Meeovi/*"
      ]
    }
    ,
    "typeRoots": ["./types", "./node_modules/@types"]
  },
  "include": [
    "packages/modules/alternate-gateway/core/src/**/*",
    "packages/modules/api/**/*",
    "layers/shared/**/*",
    "layers/social/**/*",
    "layers/commerce/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/node_modules/**",
    "**/dist/**",
    "**/__tests__/**",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "**/*.test.ts",
    "**/*.test.tsx"
  ]
}
