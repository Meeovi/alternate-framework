# Global .env.example for Alternate Framework

# Search (Searchkit/OpenSearch/Elasticsearch)
SEARCHKIT_HOST=https://search.example.com
SEARCHKIT_PROTOCOL=https
SEARCHKIT_HOSTNAME=search.example.com
SEARCHKIT_PORT=9200
SEARCHKIT_API_KEY=your_search_api_key_here
SEARCH_INDEX=default

# Embeddings / semantic rerank API (server-side)
EMBEDDINGS_API_URL=https://embeddings.example.com/api/rerank
EMBEDDINGS_API_KEY=your_embeddings_api_key_here

# Meilisearch example
MEILI_HOST=http://localhost:7700
MEILI_INDEX=products
MEILI_KEY=masterKey

# Database (example)
DATABASE_PROVIDER=postgresql
DATABASE_URL=postgresql://user:pass@localhost:5432/dbname

# Optional: expose public values to client by prefixing with NUXT_PUBLIC_
# e.g. NUXT_PUBLIC_SEARCHKIT_HOST=https://search.example.com
