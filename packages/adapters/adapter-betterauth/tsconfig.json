{
  "compilerOptions": {
    "declaration": true,
    "emitDeclarationOnly": false,
    "outDir": "dist",
    "moduleResolution": "nodenext",
    "module": "NodeNext",
    "target": "ESNext",
    "strict": true,
    "jsx": "react-jsx",
    "skipLibCheck": true, 
    "noEmitOnError": false
  },
  "include": ["src", "index.ts"]
}
