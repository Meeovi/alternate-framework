{
  "extends": "../../../tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "emitDeclarationOnly": false,
    "outDir": "dist",
    "moduleResolution": "node",
    "module": "ESNext",
    "target": "ESNext",
    "strict": true,
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "noImplicitAny": false,
    "noEmitOnError": false,
    "plugins": [{
      "name": "@0no-co/graphqlsp",
      "schema": "./schema.graphql"
    }],
    "paths": {
      "@mframework/core": ["../../../packages/modules/core/src"],
      "@mframework/core/*": ["../../../packages/modules/core/src/*"],
      "@mframework/core": ["../../../packages/modules/sdk/src"],
      "@mframework/core/*": ["../../../packages/modules/sdk/src/*"],
      "@mframework/layer-commerce": ["../../../layers/commerce"],
      "@mframework/layer-commerce/*": ["../../../layers/commerce/*"]
    }
  },
  "include": ["src", "index.ts", "tsconfig.json"],
  "exclude": ["node_modules", "dist", "tests", "src/graphql/**"]
}