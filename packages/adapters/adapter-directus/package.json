{
  "name": "@mframework/adapter-directus",
  "version": "0.0.3",
  "license": "MIT",
  "description": "Directus Client Library with auto generating forms and tables, Directus SDK and Types, and vue/react components for Directus Visual Editing.",
  "type": "module",
  "author": {
    "name": "M Framework"
  },
  "exports": {
    ".": {
      "import": "./dist/module.mjs",
      "types": "./dist/module.d.mts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "nuxt-module-build build",
    "dev": "nuxi dev playground",
    "dev:build": "nuxi build playground",
    "dev:prepare": "nuxt-module-build --stub && nuxi prepare playground",
    "docs": "cd docs && pnpm dev",
    "release": "nuxt-module-build && changelogen --release --minor --push && pnpm publish",
    "lint": "eslint --ext .js,.ts,.vue"
  },
  "dependencies": {
    "@directus/sdk": "^21.3.0",
    "@directus/types": "^15.0.3",
    "@directus/visual-editing": "^2.0.1",
    "@nuxt/kit": "^4.4.5",
    "defu": "^6.1.4",
    "ufo": "^1.6.4"
  },
  "devDependencies": {
    "@nuxt/devtools": "^0.4.2",
    "@nuxt/module-builder": "latest",
    "@nuxtjs/eslint-config-typescript": "latest",
    "@types/node": "^18.14.1",
    "changelogen": "^0.4.1",
    "eslint": "latest",
    "nuxt": "^4.4.5",
    "typescript": "^6.0.3"
  },
  "keywords": [
    "nuxt",
    "directus",
    "nuxtjs",
    "nuxt-module",
    "vue3",
    "nuxt3",
    "directus-module",
    "nuxt-directus",
    "nuxtdirectus",
    "nuxt-community"
  ],
  "unbuild": {
    "failOnWarn": false
  }
}
