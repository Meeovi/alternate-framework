{
  "name": "alternate-locate",
  "version": "0.0.1",
  "description": "Framework-agnostic i18n auto-detect engine",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./createLocate": "./src/createLocate.ts",
    "./types": "./src/types/index.ts",
    "./utils": "./src/utils/index.ts",
    "./detectors/browser": "./src/detectors/browser.ts",
    "./detectors/cookie": "./src/detectors/cookie.ts",
    "./detectors/header": "./src/detectors/header.ts",
    "./detectors/geo": "./src/detectors/geo.ts",
    "./adapters/nuxt/plugin": "./src/adapters/nuxt/plugin.ts",
    "./adapters/nuxt/i18n": "./src/adapters/nuxt/i18n.ts",
    "./adapters/nuxt/i18n.config": "./src/adapters/nuxt/i18n.config.ts",
    "./adapters/nuxt/localeDetector": "./src/adapters/nuxt/localeDetector.ts",
    "./adapters/vue/composable": "./src/adapters/vue/composable.ts"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "npm run typecheck"
  },
  "keywords": [
    "i18n",
    "nuxt",
    "vue",
    "localization"
  ],
  "author": "M Framework",
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "vue": "^3.4.0"
  }
}
