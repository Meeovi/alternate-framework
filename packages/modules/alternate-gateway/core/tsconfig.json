{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": false,
    "rootDir": ".",
    "outDir": "dist",
    "declaration": true,
    "lib": ["ES2020", "DOM"],
    "resolveJsonModule": true
  },
  "include": ["**/*.ts", "**/*.d.ts"]
}
