{
  "name": "alternate-gateway",
  "version": "1.0.0",
  "description": "The most comprehensive API framework for TypeScript.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://framework.meeovi.com/gateway",
  "keywords": [
    "gateway",
    "graphql",
    "typescript",
    "nextjs",
    "sqlite",
    "graphql-codegen",
    "graphql-tools",
    "graphql-mesh",
    "postgrahile",
    "apollo-federation",
    "graphql-yoga",
    "meeovi",
    "mframework-core",
    "vue",
    "react",
    "typescript",
    "api",
    "graphql",
    "apollo",
    "meeovi",
    "videojs",
    "m-framework"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --dts --format esm",
    "dev": "tsdown index.ts --watch",
    "test": "vitest",
    "coverage": "vitest run --coverage --coverage.provider=istanbul",
    "demo:smoke": "./demo/smoke-test.sh",
    "demo:smoke:nuxt": "ROUTE_PREFIX=/gateway ./demo/smoke-test.sh",
    "lint:package": "publint run --strict",
    "lint:types": "attw --profile esm-only --pack .",
    "test:adapters": "vitest run --config vitest.config.adapters.ts",
    "typecheck": "tsc --project tsconfig.json"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./createLocate": "./dist/domains/i18n/createLocate.js",
    "./types": "./dist/domains/i18n/types/index.js",
    "./utils": "./dist/domains/i18n/utils/index.js",
    "./detectors/browser": "./dist/domains/i18n/detectors/browser.js",
    "./detectors/cookie": "./dist/domains/i18n/detectors/cookie.js",
    "./detectors/header": "./dist/domains/i18n/detectors/header.js",
    "./detectors/geo": "./dist/domains/i18n/detectors/geo.js",
    "./adapters/nuxt/plugin": "./dist/domains/i18n/adapters/nuxt/plugin.js",
    "./adapters/nuxt/i18n": "./dist/domains/i18n/adapters/nuxt/i18n.js",
    "./adapters/nuxt/i18n.config": "./dist/domains/i18n/adapters/nuxt/i18n.config.js",
    "./adapters/nuxt/localeDetector": "./dist/domains/i18n/adapters/nuxt/localeDetector.js",
    "./adapters/vue/composable": "./dist/domains/i18n/adapters/vue/composable.js",
    "./mesh-compose": "./src/mesh-compose.ts",
    "./createMediaEngine": "./src/domains/media/createMediaEngine.ts",
    "./analytics": "./src/domains/media/analytics/index.ts",
    "./players/videojs": "./src/domains/media/players/videojs/index.ts",
    "./players/hls": "./src/domains/media/players/hls/index.ts",
    "./adapters/vue": "./src/domains/media/adapters/vue/MediaPlayer.vue",
    "./styles/media.css": "./src/domains/media/styles/media.css"
  },
  "dependencies": {
    "@apollo/client": "^4.1.0",
    "@escape.tech/graphql-armor": "^3.2.0",
    "@escape.tech/graphql-armor-max-directives": "^2.3.1",
    "@graphile/depth-limit": "^0.3.1",
    "@graphql-hive/gateway": "^2.5.14",
    "@graphql-hive/router-runtime": "^1.2.1",
    "@graphql-mesh/compose-cli": "^1.5.14",
    "@graphql-mesh/plugin-newrelic": "^0.104.36",
    "@graphql-tools/executor-http": "^3.1.1",
    "@graphql-tools/merge": "^9.1.1",
    "@graphql-tools/schema": "^10.0.25",
    "@graphql-yoga/apollo-managed-federation": "^0.17.1",
    "@graphql-yoga/plugin-apq": "^3.18.1",
    "@graphql-yoga/plugin-csrf-prevention": "^3.18.1",
    "@graphql-yoga/plugin-defer-stream": "^3.18.1",
    "@graphql-yoga/plugin-persisted-operations": "^3.18.1",
    "@graphql-yoga/plugin-prometheus": "^6.13.1",
    "@graphql-yoga/plugin-response-cache": "^3.20.1",
    "@graphql-yoga/plugin-sofa": "^3.18.1",
    "@nuxtjs/i18n": "^10.3.0",
    "@videojs/http-streaming": "^3.13.1",
    "@videojs/themes": "^1.0.1",
    "@vue/apollo-composable": "^4.2.2",
    "@vueuse/core": "^14.0.0",
    "@whatwg-node/server-plugin-cookies": "^1.0.5",
    "cross-fetch": "^4.1.0",
    "grapesjs": "^0.22.14",
    "graphql": "^16.12.0",
    "graphql-tag": "^2.12.6",
    "graphql-yoga": "^5.18.1",
    "prom-client": "^15.1.3",
    "video.js": "^8.23.4",
    "videojs-contrib-ads": "^7.1.0",
    "videojs-contrib-quality-levels": "latest",
    "videojs-hls-quality-selector": "^2.0.0",
    "videojs-persist": "^0.2.0",
    "videojs-quality-selector-hls": "^1.1.1",
    "videojs-share": "^3.2.1",
    "videojs-vr": "^2.0.0",
    "videojs-wavesurfer": "^3.10.0",
    "vue": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^5.0.5",
    "@graphql-codegen/typed-document-node": "^5.1.0",
    "@graphql-eslint/eslint-plugin": "^4.4.0",
    "@types/node": "^25.0.10",
    "@types/video.js": "^7.3.58",
    "dotenv": "^17.2.4",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3"
  }
}
