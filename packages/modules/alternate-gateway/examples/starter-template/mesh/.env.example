# Mesh Configuration
# Which adapter to use (graphql-backend, rest-backend, magento)
MESH_ADAPTER=graphql-backend

# GraphQL Backend
GRAPHQL_BACKEND_ENDPOINT=http://localhost:4000/graphql

# REST Backend
REST_BACKEND_ENDPOINT=http://localhost:3001

# Magento GraphQL
MAGENTO_GRAPHQL_ENDPOINT=https://your-magento-instance.com/graphql
MAGENTO_STORE_CODE=default

# Environment (local, staging, production)
NODE_ENV=local
