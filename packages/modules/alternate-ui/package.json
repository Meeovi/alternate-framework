{
  "name": "alternate-ui",
  "version": "0.1.0",
  "description": "Framework-agnostic UI system for Alternate Framework.",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./shared-ui": "./src/shared-ui/index.ts",
    "./shared-ui/components": "./src/shared-ui/components/index.ts",
    "./shared-ui/composables": "./src/shared-ui/composables/index.ts",
    "./shared-ui/nuxt": "./src/shared-ui/nuxt/index.ts",
    "./shared-ui/tokens": "./src/shared-ui/tokens/index.ts",
    "./vuetify": "./src/shared-ui/vuetify/index.ts",
    "./storefront": "./src/shared-ui/storefront/index.ts",
    "./storefront/tailwind.css": "./src/shared-ui/storefront/tailwind.css",
    "./storefront/styles.css": "./src/shared-ui/storefront/styles.css",
    "./adapters/nuxt/theme.client": "./src/adapters/nuxt/theme.client.ts",
    "./adapters/nuxt/theme.server": "./src/adapters/nuxt/theme.server.ts",
    "./nuxt": "./src/shared-ui/nuxt/index.ts",
    "./nuxt/module": "./src/shared-ui/nuxt/module.ts",
    "./tokens": "./src/tokens/index.ts",
    "./composables": "./src/shared-ui/composables/index.ts",
    "./vue": "./src/adapters/vue/plugin.ts",
    "./styles.css": "./src/styles/index.css",
    "./components/*": "./src/components/*",
    "./utils": "./src/utils/index.ts"
  },
  "scripts": {
    "build": "npm run typecheck",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json"
  },
  "keywords": [
    "ui",
    "design-system",
    "vue",
    "components",
    "tokens"
  ],
  "files": [
    "src"
  ],
  "sideEffects": [
    "./src/styles/index.css",
    "./src/shared-ui/storefront/tailwind.css",
    "./src/shared-ui/storefront/styles.css"
  ],
  "license": "MIT",
  "type": "module",
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "dependencies": {
    "@nuxt/kit": "^4.4.2",
    "@tailwindcss/typography": "^0.5.19",
    "@fortawesome/vue-fontawesome": "^3.1.2",
    "@nuxt/image": "^2.0.0",
    "@storefront-ui/nuxt": "^3.3.0",
    "@storefront-ui/vue": "^3.1.1",
    "@vueuse/core": "^14.0.0",
    "@vueuse/motion": "^3.0.3",
    "lg-thumbnail": "^1.2.1",
    "lg-video": "^1.4.0",
    "lg-zoom": "^1.3.0",
    "lightgallery": "^2.9.0",
    "nuxt-og-image": "^6.3.1",
    "vue": "^3.5.0",
    "vuetify-nuxt-module": "^0.19.5",
    "vuetify": "^3.8.0"
  },
  "devDependencies": {
    "sass-embedded": "^1.93.3",
    "typescript": "^5.9.3",
    "vue-tsc": "^3.1.0"
  }
}
