{
  "name": "alternate-search",
  "version": "1.0.0",
  "description": "The most comprehensive search framework for TypeScript.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://framework.meeovi.com/search",
  "keywords": [
    "search",
    "full-text",
    "typescript",
    "nextjs",
    "sqlite",
    "meilisearch",
    "typesense",
    "elasticsearch",
    "pgvector"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown index.ts",
    "dev": "tsdown index.ts --watch",
    "test": "vitest",
    "coverage": "vitest run --coverage --coverage.provider=istanbul",
    "demo:smoke": "./demo/smoke-test.sh",
    "demo:smoke:nuxt": "ROUTE_PREFIX=/search ./demo/smoke-test.sh",
    "lint:package": "publint run --strict",
    "lint:types": "attw --profile esm-only --pack .",
    "test:adapters": "vitest run --config vitest.config.adapters.ts",
    "typecheck": "tsc --project tsconfig.json"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
