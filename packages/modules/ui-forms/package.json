{
  "name": "@mframework/ui-forms",
  "version": "0.1.0",
  "description": "Schema-driven, backend-agnostic JSON forms module for M Framework.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./components/*": {
      "import": "./src/components/*"
    },
    "./nuxt-layer": {
      "import": "./nuxt-layer/index.ts"
    },
    "./schemas/*": {
      "import": "./src/schemas/*"
    }
  },
  "files": [
    "dist",
    "src",
    "nuxt-layer",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepare": "npm run build",
    "prepack": "npm run build",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@jsonforms/core": "^3.8.0",
    "@jsonforms/vue": "^3.8.0",
    "@jsonforms/vue-vuetify": "^3.8.0",
    "maska": "^2.1.11",
    "zod": "^3.24.0"
  },
  "peerDependencies": {
    "nuxt": "^4.0.0",
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@types/node": "latest",
    "typescript": "~6.0.3"
  }
}
