{
  "name": "@mframework/ui-forms",
  "version": "0.1.0",
  "description": "Schema-driven, backend-agnostic JSON forms module for M Framework.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./components/*": "./src/components/*",
    "./nuxt-layer": "./nuxt-layer/index.ts",
    "./schemas/*": "./src/schemas/*"
  },
  "files": [
    "dist",
    "src",
    "nuxt-layer",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "zod": "^3.24.0"
  },
  "peerDependencies": {
    "vue": "^3.4.0",
    "nuxt": "^4.0.0"
  },
  "devDependencies": {
    "typescript": "~6.0.3",
    "@types/node": "latest"
  }
}
