{
  "compilerOptions": {
    "declaration": true,
    "emitDeclarationOnly": false,
    "outDir": "dist",
    "moduleResolution": "bundler",
    "module": "ESNext",
    "target": "ESNext",
    "strict": true,
    "jsx": "react-jsx",
    "skipLibCheck": true, 
    "noEmitOnError": false
  },
  "include": ["runtime/**/*", "src/**/*", "types/**/*", "../../adapters/adapter-directus/src/types/ui.ts"],
  "exclude": ["node_modules", "dist"]
}
