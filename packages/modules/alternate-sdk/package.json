{
  "name": "alternate-sdk",
  "version": "1.0.0",
  "description": "Official SDK for M Framework, providing a comprehensive set of tools and utilities for seamless integration and development with the M Framework ecosystem.",
  "repository": "mframework/alternate-sdk",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./auth": {
      "types": "./dist/auth/index.d.ts",
      "import": "./dist/auth/index.js"
    },
    "./auth/adapter": {
      "types": "./dist/auth/adapter.d.ts",
      "import": "./dist/auth/adapter.js"
    },
    "./auth/server": {
      "types": "./dist/auth/server.d.ts",
      "import": "./dist/auth/server.js"
    },
    "./commerce": {
      "types": "./dist/commerce/index.d.ts",
      "import": "./dist/commerce/index.js"
    },
    "./commerce/adapter": {
      "types": "./dist/commerce/adapter.d.ts",
      "import": "./dist/commerce/adapter.js"
    },
    "./commerce/server": {
      "types": "./dist/commerce/server.d.ts",
      "import": "./dist/commerce/server.js"
    },
    "./content": {
      "types": "./dist/content/index.d.ts",
      "import": "./dist/content/index.js"
    },
    "./content/adapter": {
      "types": "./dist/content/adapter.d.ts",
      "import": "./dist/content/adapter.js"
    },
    "./content/server": {
      "types": "./dist/content/server.d.ts",
      "import": "./dist/content/server.js"
    },
    "./search": {
      "types": "./dist/search/index.d.ts",
      "import": "./dist/search/index.js"
    },
    "./search/adapter": {
      "types": "./dist/search/adapter.d.ts",
      "import": "./dist/search/adapter.js"
    },
    "./search/server": {
      "types": "./dist/search/server.d.ts",
      "import": "./dist/search/server.js"
    },
    "./federation": {
      "types": "./dist/federation/index.d.ts",
      "import": "./dist/federation/index.js"
    },
    "./federation/adapter": {
      "types": "./dist/federation/adapter.d.ts",
      "import": "./dist/federation/adapter.js"
    },
    "./federation/server": {
      "types": "./dist/federation/server.d.ts",
      "import": "./dist/federation/server.js"
    }
  },
  "main": "./dist/index.js",
  "typesVersions": {
    "*": {
      ".": ["./dist/index.d.ts"],
      "auth": ["./dist/auth/index.d.ts"],
      "auth/adapter": ["./dist/auth/adapter.d.ts"],
      "auth/server": ["./dist/auth/server.d.ts"],
      "commerce": ["./dist/commerce/index.d.ts"],
      "commerce/adapter": ["./dist/commerce/adapter.d.ts"],
      "commerce/server": ["./dist/commerce/server.d.ts"],
      "content": ["./dist/content/index.d.ts"],
      "content/adapter": ["./dist/content/adapter.d.ts"],
      "content/server": ["./dist/content/server.d.ts"],
      "search": ["./dist/search/index.d.ts"],
      "search/adapter": ["./dist/search/adapter.d.ts"],
      "search/server": ["./dist/search/server.d.ts"],
      "federation": ["./dist/federation/index.d.ts"],
      "federation/adapter": ["./dist/federation/adapter.d.ts"],
      "federation/server": ["./dist/federation/server.d.ts"]
    }
  },
  "files": [
    "dist"
  ],
  "workspaces": [
    "playground"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest watch"
  },
  "dependencies": {
    "alternate-auth": "file:../alternate-auth"
  },
  "devDependencies": {
    "@types/node": "latest",
    "eslint": "^10.3.0",
    "typescript": "~6.0.3",
    "vitest": "^4.1.5"
  }
}
